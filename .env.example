# =============================================================================
# FootballQ AI - Environment Variable Template
# =============================================================================
# Copy this file to `.env.local` (frontend) and/or Azure Functions
# "Application Settings" (backend). NEVER commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND (Vercel) - only NEXT_PUBLIC_* variables are exposed to the browser
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=FootballQ AI
NEXT_PUBLIC_API_BASE_URL=https://your-azure-functions-url.azurewebsites.net/api
NEXT_PUBLIC_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# BACKEND (Azure Functions Application Settings)
# -----------------------------------------------------------------------------
ENVIRONMENT=production

# Azure SQL Database (SQL Server-compatible). Use the ODBC connection string
# format. Never commit a real value - set this only in Azure Functions
# Application Settings.
AZURE_SQL_CONNECTION_STRING=

# Comma-separated list of allowed CORS origins for the public frontend
ALLOWED_ORIGINS=https://footballq-ai.vercel.app

# Mock LLM mode (zero-cost). Keep true for the free public deployment.
USE_MOCK_LLM=true

# Optional real LLM (disabled by default - may incur OpenAI costs)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
ENABLE_REAL_LLM=false

# Optional Qdrant free-tier vector search (app works fully without this)
ENABLE_QDRANT=false
QDRANT_URL=
QDRANT_API_KEY=

# Rate limiting / logging
RATE_LIMIT_ENABLED=true
LOG_LEVEL=INFO

# Optional MCP module (not required for the public website)
MCP_ENABLED=false

# Optional FBref data pipeline (see docs/FBREF_PIPELINE.md). Disabled by
# default; requires AZURE_SQL_CONNECTION_STRING to be set.
FBREF_PIPELINE_ENABLED=false
FBREF_SEASON=2025-2026
FBREF_REQUEST_DELAY_SECONDS=6.0
FBREF_MATCHLOG_TEAMS_PER_RUN=2
FBREF_EXTRA_LEAGUES_PER_RUN=1
FBREF_USER_AGENT=
